<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  testng.xml — FULL suite
  Runs every test tagged with group "full": all 19 tests across 4 APIs.
  Execute: mvn test -DsuiteXmlFile=testng.xml
  See testng-smoke.xml and testng-regression.xml for targeted runs.
-->
<suite name="REST Assured API Test Suite — Full" verbose="2" parallel="false">

    <listeners>
        <listener class-name="org.testng.reporters.JUnitReportReporter"/>
    </listeners>

    <!-- ── GitHub OAuth 2.0 ── -->
    <test name="GitHub API Tests (OAuth 2.0)" preserve-order="true">
        <groups>
            <run>
                <include name="full"/>
            </run>
        </groups>
        <classes>
            <class name="com.apiframework.tests.github.GitHubTests"/>
        </classes>
    </test>

    <!-- ── Restful-Booker Cookie Token ── -->
    <test name="Restful-Booker API Tests (Cookie Token)" preserve-order="true">
        <groups>
            <run>
                <include name="full"/>
            </run>
        </groups>
        <classes>
            <class name="com.apiframework.tests.booker.BookerTests"/>
        </classes>
    </test>

    <!-- ── Platzi Fake Store JWT ── -->
    <test name="Platzi Fake Store API Tests (JWT)" preserve-order="true">
        <groups>
            <run>
                <include name="full"/>
            </run>
        </groups>
        <classes>
            <class name="com.apiframework.tests.platzi.PlatziTests"/>
        </classes>
    </test>

    <!-- ── WireMock (embedded mock server) ── -->
    <test name="WireMock Tests (Embedded Mock Server)" preserve-order="true">
        <groups>
            <run>
                <include name="full"/>
            </run>
        </groups>
        <classes>
            <class name="com.apiframework.tests.wiremock.WireMockTests"/>
        </classes>
    </test>

    <!-- ── Pure programmatic stub demonstration ── -->
    <test name="Stub Demo Tests (Pure Programmatic Stubbing)" preserve-order="true">
        <groups>
            <run>
                <include name="full"/>
            </run>
        </groups>
        <classes>
            <class name="com.apiframework.tests.stub.StubDemoTests"/>
        </classes>
    </test>

</suite>
