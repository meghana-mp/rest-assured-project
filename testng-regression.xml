<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  testng-regression.xml — REGRESSION suite
  Runs all tests tagged with group "regression": all 17 tests (excludes TC_WM_003/004).
    GitHub   — TC_GH_001 through TC_GH_005
    Booker   — TC_RB_001 through TC_RB_006
    Platzi   — TC_PF_001 through TC_PF_005
    WireMock — TC_WM_001 (file-based GET), TC_WM_002 (stubbed POST with body matching)
  Execute: mvn test -DsuiteXmlFile=testng-regression.xml
-->
<suite name="REST Assured API Test Suite — Regression" verbose="2" parallel="false">

    <listeners>
        <listener class-name="org.testng.reporters.JUnitReportReporter"/>
    </listeners>

    <!-- ── GitHub OAuth 2.0 ── -->
    <test name="GitHub API Tests — Regression" preserve-order="true">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.apiframework.tests.github.GitHubTests"/>
        </classes>
    </test>

    <!-- ── Restful-Booker Cookie Token ── -->
    <test name="Restful-Booker API Tests — Regression" preserve-order="true">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.apiframework.tests.booker.BookerTests"/>
        </classes>
    </test>

    <!-- ── Platzi Fake Store JWT ── -->
    <test name="Platzi Fake Store API Tests — Regression" preserve-order="true">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.apiframework.tests.platzi.PlatziTests"/>
        </classes>
    </test>

    <!-- ── WireMock (embedded mock server) ── -->
    <test name="WireMock Tests — Regression" preserve-order="true">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.apiframework.tests.wiremock.WireMockTests"/>
        </classes>
    </test>

    <!-- ── Pure programmatic stub demonstration ── -->
    <test name="Stub Demo Tests — Regression" preserve-order="true">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.apiframework.tests.stub.StubDemoTests"/>
        </classes>
    </test>

</suite>
